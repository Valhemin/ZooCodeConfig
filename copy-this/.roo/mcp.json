{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp@latest"
			],
			"timeout": 90,
			"disabled": false,
			"alwaysAllow": [
				"resolve-library-id"
			]
		},
		"agentmemory": {
			"command": "npx",
			"args": [
				"-y",
				"@agentmemory/mcp"
			],
			"timeout": 120,
			"disabled": false,
			"alwaysAllow": []
		},
		"tavily": {
			"command": "npx",
			"args": [
				"-y",
				"tavily-mcp@latest"
			],
			"env": {
				"TAVILY_API_KEY": "${env:TAVILY_API_KEY}"
			},
			"timeout": 120,
			"disabled": true
		},
		"playwright": {
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp@latest",
				"--headless"
			],
			"timeout": 120,
			"disabled": true
		},
		"chrome-devtools": {
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@latest",
				"--headless",
				"--isolated",
				"--no-usage-statistics",
				"--no-performance-crux"
			],
			"timeout": 120,
			"disabled": true
		},
		"github": {
			"type": "streamable-http",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"Authorization": "Bearer ${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
			},
			"timeout": 120,
			"disabled": true
		},
		"figma": {
			"type": "streamable-http",
			"url": "https://mcp.figma.com/mcp",
			"timeout": 120,
			"disabled": true
		},
		"figma-desktop": {
			"type": "sse",
			"url": "http://127.0.0.1:3845/sse",
			"timeout": 120,
			"disabled": true
		},
		"brave-search": {
			"command": "npx",
			"args": [
				"-y",
				"@anthropic-ai/mcp-server-brave-search"
			],
			"env": {
				"BRAVE_API_KEY": "${env:BRAVE_API_KEY}"
			},
			"timeout": 90,
			"disabled": true
		}
	}
}
